# Database — local Docker Postgres (docker compose up -d postgres)
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@127.0.0.1:5432/bdt_dev?schema=public"

PORT=3000
NODE_ENV=development

# File storage (Sprint 3+ shop drawings)
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_PATH=./storage

# Cutting Plan — external Python parsing service (Cloud Run, IAM-authenticated;
# local dev needs `gcloud auth application-default login` for ID-token minting)
CUTTING_PLAN_API_URL=https://bdt-cutting-plan-service-jr5hvzmn5q-an.a.run.app

# Sprint 23: BIM Viewer — Autodesk Platform Services (APS) app credentials
# Create an app at https://aps.autodesk.com — needs Data Management + Model Derivative APIs enabled
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_BUCKET_KEY=bdt-bim-dev
