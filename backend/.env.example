# Database — connects via Cloud SQL Auth Proxy (proxy must be running on 127.0.0.1:5432)
# Run scripts/proxy-up.sh first, then scripts/setup-env.sh to populate this from Secret Manager
DATABASE_URL="postgresql://bdt:<DB_PASSWORD>@127.0.0.1:5432/bdt_dev?schema=public"

PORT=3000
NODE_ENV=development

# GCP Cloud SQL
INSTANCE_CONNECTION_NAME="<PROJECT_ID>:asia-southeast1:bdt-dev-postgres"
GCP_PROJECT_ID="<PROJECT_ID>"


# File storage (Sprint 3+ shop drawings)
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_PATH=./storage
