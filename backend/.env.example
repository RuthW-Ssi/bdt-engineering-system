# Database — connects via Cloud SQL Auth Proxy (proxy must be running on 127.0.0.1:5432)
# Run scripts/setup-env.sh to populate DATABASE_URL from GCP Secret Manager (bdt-dev-database-url)
DATABASE_URL="postgresql://postgres:<DB_PASSWORD>@127.0.0.1:5432/dev-bdt-engineering-db?schema=public&connection_limit=5"

PORT=3000
NODE_ENV=development

# GCP Cloud SQL — Secret naming convention: bdt-dev-<var-name>
INSTANCE_CONNECTION_NAME="building-technology-493907:asia-southeast1:dev-bdt-engineering-db"
GCP_PROJECT_ID="building-technology-493907"

# File storage (Sprint 3+ shop drawings)
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_PATH=./storage
