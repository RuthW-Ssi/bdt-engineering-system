generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler (PgBouncer, port 6543)
  directUrl = env("DIRECT_URL") // direct — Prisma uses this for migrations
}

// ── 🟦 Standard Odoo: res_users (Sprint 6: JWT auth fields) ──
model res_users {
  id          Int      @id @default(autoincrement())
  login       String   @unique @db.VarChar(60)
  password    String   @default("") @db.VarChar(128) // bcryptjs hash; empty = not yet set
  name        String   @db.VarChar(120)
  email       String?  @db.VarChar(120)
  lang        String?  @default("th_TH") @db.VarChar(10)
  tz          String?  @default("Asia/Bangkok") @db.VarChar(40)
  role        String   @default("user") @db.VarChar(20) // "admin" | "user"
  partner_id  Int? // FK placeholder → res_partner (Sprint 7)
  active      Boolean  @default(true)
  create_date DateTime @default(now()) @db.Timestamptz
  write_date  DateTime @updatedAt @db.Timestamptz

  materials_created materials[]    @relation("create_user")
  materials_written materials[]    @relation("write_user")
  messages          mail_message[]

  // Sprint 2: Project + Product relations
  projects_created        project[]         @relation("project_create")
  projects_written        project[]         @relation("project_write")
  products_created        products[]        @relation("product_create")
  products_written        products[]        @relation("product_write")
  product_library_created product_library[] @relation("pl_create")
  product_library_written product_library[] @relation("pl_write")

  // Sprint 3: BOM + Drawing audit
  boms_created      product_bom[]      @relation("bom_create")
  boms_written      product_bom[]      @relation("bom_write")
  drawings_created  shop_drawing[]     @relation("drawing_create")
  drawings_written  shop_drawing[]     @relation("drawing_write")
  revisions_created drawing_revision[] @relation("revision_create")
  drawing_approvals drawing_revision[] @relation("DrawingApprover")

  // Sprint 4: Routing audit
  workcenters_created mrp_workcenter[]         @relation("wc_create")
  workcenters_written mrp_workcenter[]         @relation("wc_write")
  routing_wc_created  mrp_routing_workcenter[] @relation("rwc_create")
  routing_wc_written  mrp_routing_workcenter[] @relation("rwc_write")

  // Sprint 4.2: Routing Option 3 audit
  routing_templates_created routing_template[] @relation("rt_create")
  routing_templates_written routing_template[] @relation("rt_write")

  // Sprint 4.3: History audit + simulator fixtures
  routing_template_history routing_template_history[]      @relation("rth_user")
  test_fixtures_created    routing_template_test_fixture[] @relation("rtf_create")

  // Sprint 7: BOM Dispatch audit
  bom_dispatches_created bom_dispatch[]      @relation("dispatch_create")
  bom_dispatches_written bom_dispatch[]      @relation("dispatch_write")
  bom_assemblies_created bom_assembly[]      @relation("assembly_create")
  bom_assemblies_written bom_assembly[]      @relation("assembly_write")
  bom_parts_created      bom_part[]          @relation("part_create")
  bom_parts_written      bom_part[]          @relation("part_write")
  bom_doc_revs_created   bom_doc_revision[]  @relation("docrev_create")
  bom_asm_parts_created  bom_assembly_part[] @relation("asmpart_create")

  // Sprint 12: Activity Library
  activities_created activity[] @relation("activity_create_user")
  activities_written activity[] @relation("activity_write_user")

  // Sprint 13: Manufacturing Order audit
  mos_created manufacturing_order[] @relation("mo_create")
  mos_written manufacturing_order[] @relation("mo_write")
}

model uom_uom {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(40)
  factor      Decimal @default(1) @db.Decimal(12, 6)
  uom_type    String  @default("reference") @db.VarChar(10)
  rounding    Decimal @default(0.01) @db.Decimal(12, 6)
  active      Boolean @default(true)
  odoo_ref_id String? @db.VarChar(40)

  materials_uom    materials[]        @relation("uom")
  materials_uom_po materials[]        @relation("uom_po")
  bom_lines        product_bom_line[] @relation("BomLineUom")
  bom_headers      product_bom[]      @relation("bom_uom")
}

// ── 🟨 Hybrid: product_category (Odoo tree + BDT extension) ──
model product_category {
  id                Int                @id @default(autoincrement())
  name              String             @db.VarChar(80)
  parent_id         Int?
  parent            product_category?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children          product_category[] @relation("CategoryTree")
  complete_name     String?            @db.VarChar(200)
  group_no          String?            @db.VarChar(10)
  prefix_5          String?            @unique @db.Char(5)
  needs_criticality Boolean            @default(false)
  active            Boolean            @default(true)
  odoo_ref_id       String?            @db.VarChar(40)

  materials         materials[]
  products          products[]
  routing_templates routing_template[]
}

// ── 🟦/🟨/🟥 materials ────────────────────────────────────────
model materials {
  id               Int              @id @default(autoincrement())
  default_code     String           @unique @db.Char(10)
  name             String           @db.VarChar(200)
  description_sale String           @db.VarChar(200)
  categ_id         Int
  category         product_category @relation(fields: [categ_id], references: [id])
  uom_id           Int
  uom              uom_uom          @relation("uom", fields: [uom_id], references: [id])
  uom_po_id        Int?
  uom_po           uom_uom?         @relation("uom_po", fields: [uom_po_id], references: [id])
  type             String           @default("product") @db.VarChar(20)
  state            String           @default("draft") @db.VarChar(20)
  active           Boolean          @default(true)
  version          String?          @db.VarChar(10)
  substitute_for   Int?
  substitute_ref   materials?       @relation("SubstituteMaterials", fields: [substitute_for], references: [id])
  substitutes      materials[]      @relation("SubstituteMaterials")
  substitute_seq   Int?             @db.SmallInt
  priority         String?          @db.Char(1)
  criticality      String?          @db.VarChar(2)
  attributes       Json             @default("{}")
  drawing_ref      String?          @db.VarChar(60)
  bim_object_id    String?          @db.VarChar(80)
  total_weight_kg  Decimal?         @db.Decimal(12, 3)
  odoo_ref_id      String?          @db.VarChar(40)
  create_uid       Int
  create_user      res_users        @relation("create_user", fields: [create_uid], references: [id])
  create_date      DateTime         @default(now()) @db.Timestamptz
  write_uid        Int
  write_user       res_users        @relation("write_user", fields: [write_uid], references: [id])
  write_date       DateTime         @default(now()) @db.Timestamptz

  bom_lines                product_bom_line[]                 @relation("BomLineMaterial")
  paint_configs            dispatch_assembly_paint_config[]   @relation("PaintConfigMaterial")
  material_requirements    dispatch_material_requirement[]    @relation("MaterialRequirements")
  assembly_welding_configs dispatch_assembly_welding_config[] @relation("AssemblyWeldingConfigMaterial")
  welding_requirements     dispatch_welding_requirement[]     @relation("WeldingRequirements")
}

// ── 🟥 Custom: part_code_seq (concurrency-safe counter) ──────
model part_code_seq {
  prefix_5 String @id @db.Char(5)
  next_run Int    @default(1)
}

// ── 🟥 Custom: product_code_seq (STD / CUS product counter) ──
model product_code_seq {
  kind     String @id @db.VarChar(10)
  next_run Int    @default(1)
}

// ── 🟥 Custom: product_library_seq (LIB-NNN counter) ─────────
model product_library_seq {
  id    Int @id @default(1)
  value Int @default(0)
}

// ── 🟥 Custom: product_library (canonical product-name catalog) ──
// Sprint 11: governance layer — STD products must link here (CUS optional)
model product_library {
  id                   Int       @id @default(autoincrement())
  code                 String    @unique @db.VarChar(20) // LIB-NNN auto via product_library_seq
  name                 String    @unique @db.VarChar(200) // canonical product name (uppercase, case-insensitive UNIQUE enforced in service)
  mark_prefix          String?   @db.VarChar(10)
  mark_prefix_label    String?   @db.VarChar(40)
  mark_prefix_category String?   @db.VarChar(20)
  active               Boolean   @default(true)
  create_uid           Int
  create_user          res_users @relation("pl_create", fields: [create_uid], references: [id])
  create_date          DateTime  @default(now()) @db.Timestamptz
  write_uid            Int
  write_user           res_users @relation("pl_write", fields: [write_uid], references: [id])
  write_date           DateTime  @default(now()) @db.Timestamptz

  products products[] @relation("ProductLibraryRef")

  @@index([active])
}

// ── 🟦 Standard Odoo: mail_message (audit log — polymorphic) ─
// Sprint 2: Refactored to polymorphic — model+res_id generic reference
// Supports: 'material', 'product', 'project' (and future models)
model mail_message {
  id           BigInt       @id @default(autoincrement())
  model        String       @db.VarChar(60)
  res_id       Int
  message_type String       @db.VarChar(20)
  subject      String?      @db.VarChar(200)
  body         String?      @db.Text
  tracking     Json?
  author_id    Int?
  author       res_users?   @relation(fields: [author_id], references: [id])
  partner_id   Int?
  partner      res_partner? @relation("PartnerMessages", fields: [partner_id], references: [id])
  date         DateTime     @default(now()) @db.Timestamptz

  @@index([model, res_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 6: res_partner (Customer) + sub_zone
// ═══════════════════════════════════════════════════════════════

model res_partner {
  id            Int      @id @default(autoincrement())
  ref           String?  @unique @db.VarChar(20)
  name          String   @db.VarChar(200)
  vat           String?  @db.VarChar(40)
  email         String?  @db.VarChar(120)
  phone         String?  @db.VarChar(40)
  street        String?  @db.VarChar(200)
  city          String?  @db.VarChar(80)
  country_id    Int?
  is_company    Boolean  @default(true)
  parent_id     Int?
  customer_rank Int      @default(1)
  active        Boolean  @default(true)
  create_uid    Int?
  write_uid     Int?
  create_date   DateTime @default(now()) @db.Timestamptz
  write_date    DateTime @updatedAt @db.Timestamptz

  projects      project[]
  mail_messages mail_message[] @relation("PartnerMessages")
}

// ═══════════════════════════════════════════════════════════════
// Sprint 2: Product Layer
// ═══════════════════════════════════════════════════════════════

// ── 🟦 Project ──────────────────────────────────────────────────
model project {
  id              Int          @id @default(autoincrement())
  project_code    String       @unique @db.VarChar(20)
  name            String       @db.VarChar(200)
  customer_id     Int?
  customer        res_partner? @relation(fields: [customer_id], references: [id])
  start_date      DateTime?    @db.Date
  target_handover DateTime?    @db.Date
  state           String       @default("lead") @db.VarChar(20)
  active          Boolean      @default(true)
  odoo_ref_id     String?      @db.VarChar(40)
  create_uid      Int
  create_user     res_users    @relation("project_create", fields: [create_uid], references: [id])
  create_date     DateTime     @default(now()) @db.Timestamptz
  write_uid       Int
  write_user      res_users    @relation("project_write", fields: [write_uid], references: [id])
  write_date      DateTime     @default(now()) @db.Timestamptz

  zones      project_zone[]
  products   products[]
  boms       product_bom[]  @relation("ProjectBom")
  drawings   shop_drawing[] @relation("ProjectDrawings")
  dispatches bom_dispatch[] @relation("ProjectDispatches")
}

// ── 🟥 Project Zone (erection sequence — F23 / PD-37) ──────────
model project_zone {
  id                    Int       @id @default(autoincrement())
  project_id            Int
  project               project   @relation(fields: [project_id], references: [id])
  code                  String    @db.VarChar(20)
  label                 String    @db.VarChar(80)
  erection_sequence     Int?
  target_erection_start DateTime? @db.Date
  target_erection_end   DateTime? @db.Date
  crane_assignment      String?   @db.VarChar(60)
  notes                 String?   @db.Text
  active                Boolean   @default(true)

  products   products[]
  sub_zones  sub_zone[]
  dispatches bom_dispatch[] @relation("ZoneDispatches")

  @@unique([project_id, code])
}

// ── 🟥 Sub Zone (Sprint 6: F2/ST3) ────────────────────────────
model sub_zone {
  id          Int          @id @default(autoincrement())
  zone_id     Int
  zone        project_zone @relation(fields: [zone_id], references: [id])
  name        String       @db.VarChar(80)
  code        String?      @db.VarChar(20)
  active      Boolean      @default(true)
  create_uid  Int?
  write_uid   Int?
  create_date DateTime     @default(now()) @db.Timestamptz
  write_date  DateTime     @updatedAt @db.Timestamptz

  dispatches bom_dispatch[] @relation("SubZoneDispatches")
}

// ── 🟥 Mark Prefix Master (27 entries — F9 / PD-20) ────────────
model mark_prefix_master {
  code           String  @id @db.VarChar(10)
  label          String  @db.VarChar(40)
  category       String  @db.VarChar(20)
  part_type_code String  @db.Char(1)
  active         Boolean @default(true)

  products             products[]
  manufacturing_orders manufacturing_order[] // Sprint 13: MO (P12, 1 prefix per MO)
}

// ── 🟦/🟨/🟥 Products (single-table inheritance, F4 / PD-01) ───
model products {
  id                     Int              @id @default(autoincrement())
  product_code           String           @unique @db.VarChar(20)
  engineering_code       String?          @unique @db.VarChar(20)
  item_code              String?          @unique @db.Char(10)
  odoo_compliance_status String           @default("NEW") @db.VarChar(20)
  name                   String           @db.VarChar(200)
  categ_id               Int
  category               product_category @relation(fields: [categ_id], references: [id])
  product_type           String           @db.VarChar(20)
  odoo_type              String           @default("product") @db.VarChar(10)
  procure_method         String           @default("make_to_order") @db.VarChar(20)
  state                  String           @default("draft") @db.VarChar(20)
  active                 Boolean          @default(true)
  sale_ok                Boolean          @default(false)
  purchase_ok            Boolean          @default(false)
  sales_price            Decimal          @default(1.0) @db.Decimal(12, 2)

  // Cost components (4-component, 3 levels — F7)
  cost_raw_material Decimal? @db.Decimal(12, 2)
  cost_transport    Decimal? @db.Decimal(12, 2)
  cost_production   Decimal? @db.Decimal(12, 2)
  cost_warehouse    Decimal? @db.Decimal(12, 2)
  // standard_cost_total = computed via DB GENERATED column (in raw SQL migration)

  // Standard-only fields
  master_drawing_id  Int?
  master_drawing     shop_drawing? @relation("MasterDrawingProduct", fields: [master_drawing_id], references: [id])
  variant_attributes Json?
  derivation_flags   Json          @default("[]")
  confidence         String        @default("high") @db.VarChar(10)
  stock_policy       String?       @db.VarChar(20)
  reorder_min        Decimal?      @db.Decimal(12, 3)
  reorder_max        Decimal?      @db.Decimal(12, 3)

  // Custom-only fields
  project_id         Int?
  project            project?            @relation(fields: [project_id], references: [id])
  erection_zone_id   Int?
  erection_zone      project_zone?       @relation(fields: [erection_zone_id], references: [id])
  mark_prefix        String?             @db.VarChar(10)
  mark               mark_prefix_master? @relation(fields: [mark_prefix], references: [code])
  mark_number        String?             @db.VarChar(20)
  shop_drawing_id    Int?
  shop_drawing_ref   shop_drawing?       @relation("ShopDrawingProduct", fields: [shop_drawing_id], references: [id])
  revision           String?             @db.VarChar(10)
  engineer_hours_est Decimal?            @db.Decimal(8, 2)
  engineer_hours_act Decimal?            @db.Decimal(8, 2)

  // Promotion lineage
  promoted_from_id     Int?
  promoted_from        products?  @relation("Promotion", fields: [promoted_from_id], references: [id])
  promoted_descendants products[] @relation("Promotion")
  promoted_date        DateTime?  @db.Timestamptz
  legacy_codes         String[]

  // Engineering attributes
  attributes Json @default("{}")

  // mBOM spec presets — engineer defines once, mBOM config auto-suggests
  default_paint_spec   Json?
  default_welding_spec Json?

  // Sprint 4.2: Routing Option 3
  routing_template_id Int?
  routing_template    routing_template?               @relation("ProductTemplateBind", fields: [routing_template_id], references: [id])
  simulator_fixtures  routing_template_test_fixture[] @relation("FixtureProduct")

  // Sprint 8: eBOM ↔ mBOM kind — 'assembly' | 'part' | null (legacy products)
  product_kind String? @db.VarChar(20)

  // Sprint 11: Product Library link
  library_id Int?
  library    product_library? @relation("ProductLibraryRef", fields: [library_id], references: [id], onDelete: SetNull)

  // Odoo sync
  odoo_ref_id String? @db.VarChar(40)

  // Audit
  create_uid  Int
  create_user res_users @relation("product_create", fields: [create_uid], references: [id])
  create_date DateTime  @default(now()) @db.Timestamptz
  write_uid   Int
  write_user  res_users @relation("product_write", fields: [write_uid], references: [id])
  write_date  DateTime  @default(now()) @db.Timestamptz

  boms                  product_bom[]      @relation("ProductBom")
  sub_product_bom_lines product_bom_line[] @relation("SubProductInBom")
  drawings              shop_drawing[]     @relation("ProductDrawings")
  bom_assemblies        bom_assembly[]
  bom_parts             bom_part[]

  @@index([product_kind, product_type, name])
  @@index([library_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 3: BOM + Drawings
// ═══════════════════════════════════════════════════════════════

// ── 🟦 Product BOM header (mrp.bom — Sprint 3 full spec) ────────
model product_bom {
  id                 Int           @id @default(autoincrement())
  product_id         Int
  product            products      @relation("ProductBom", fields: [product_id], references: [id])
  version            String        @default("1.0.0") @db.VarChar(20)
  bom_view           String        @default("eBOM") @db.VarChar(10)
  owner_role         String        @default("engineering") @db.VarChar(20)
  state              String        @default("draft") @db.VarChar(20)
  product_qty        Decimal       @default(1.0) @db.Decimal(12, 3)
  product_uom_id     Int
  product_uom        uom_uom       @relation("bom_uom", fields: [product_uom_id], references: [id])
  bom_type           String        @default("normal") @db.VarChar(20)
  effective_from     DateTime?     @db.Date
  effective_to       DateTime?     @db.Date
  cloned_from_bom_id Int?
  cloned_from        product_bom?  @relation("BomLineage", fields: [cloned_from_bom_id], references: [id])
  cloned_descendants product_bom[] @relation("BomLineage")
  eco_id             Int?
  notes              String?       @db.Text
  project_id         Int?
  project            project?      @relation("ProjectBom", fields: [project_id], references: [id])
  odoo_ref_id        String?       @db.VarChar(40)
  create_uid         Int
  create_user        res_users     @relation("bom_create", fields: [create_uid], references: [id])
  create_date        DateTime      @default(now()) @db.Timestamptz
  write_uid          Int
  write_user         res_users     @relation("bom_write", fields: [write_uid], references: [id])
  write_date         DateTime      @default(now()) @db.Timestamptz

  lines product_bom_line[]
}

// ── 🟦 BOM Line (mrp.bom.line + steel extensions) ───────────────
model product_bom_line {
  id                  Int                     @id @default(autoincrement())
  bom_id              Int
  bom                 product_bom             @relation(fields: [bom_id], references: [id], onDelete: Cascade)
  sequence            Int                     @default(10)
  // EXACTLY ONE of material_id or sub_product_id (CHECK constraint via manual SQL)
  material_id         Int?
  material            materials?              @relation("BomLineMaterial", fields: [material_id], references: [id])
  sub_product_id      Int?
  sub_product         products?               @relation("SubProductInBom", fields: [sub_product_id], references: [id])
  product_qty         Decimal                 @db.Decimal(12, 3)
  product_uom_id      Int
  product_uom         uom_uom                 @relation("BomLineUom", fields: [product_uom_id], references: [id])
  scrap_pct           Decimal                 @default(0) @db.Decimal(6, 2)
  attribute_value_ids Json?
  cutting_length_mm   Decimal?                @db.Decimal(10, 1)
  weight_per_unit_kg  Decimal?                @db.Decimal(10, 3)
  note                String?                 @db.Text
  // Steel-specific (imported from Tekla/XLS)
  part_mark           String?                 @db.VarChar(30)
  profile             String?                 @db.VarChar(60)
  grade               String?                 @db.VarChar(20)
  length_mm           Decimal?                @db.Decimal(10, 2)
  area_m2             Decimal?                @db.Decimal(10, 4)
  // Sprint 4 / Sprint 5: BOM line ↔ Routing operation linkage (populated by Sprint 5 import)
  operation_id        Int?
  operation           mrp_routing_workcenter? @relation("BomLineOp", fields: [operation_id], references: [id])
}

// ── 🟥 Shop Drawing (steel-domain — not in Odoo) ─────────────────
model shop_drawing {
  id                      Int            @id @default(autoincrement())
  drawing_number          String         @unique @db.VarChar(40)
  drawing_type            String         @db.VarChar(10)
  product_id              Int
  product                 products       @relation("ProductDrawings", fields: [product_id], references: [id])
  project_id              Int?
  project                 project?       @relation("ProjectDrawings", fields: [project_id], references: [id])
  current_revision        String?        @db.VarChar(5)
  state                   String         @default("draft") @db.VarChar(20)
  cad_source              String         @default("other") @db.VarChar(20)
  generalized_from_id     Int?
  generalized_from        shop_drawing?  @relation("DrawingLineage", fields: [generalized_from_id], references: [id])
  generalized_descendants shop_drawing[] @relation("DrawingLineage")
  retention_until         DateTime?      @db.Date
  odoo_ref_id             String?        @db.VarChar(40)
  create_uid              Int
  create_user             res_users      @relation("drawing_create", fields: [create_uid], references: [id])
  create_date             DateTime       @default(now()) @db.Timestamptz
  write_uid               Int
  write_user              res_users      @relation("drawing_write", fields: [write_uid], references: [id])
  write_date              DateTime       @default(now()) @db.Timestamptz

  revisions       drawing_revision[]
  master_products products[]         @relation("MasterDrawingProduct")
  shop_products   products[]         @relation("ShopDrawingProduct")
}

// ── 🟥 Drawing Revision (A→B→C→IFC→AB lifecycle) ────────────────
model drawing_revision {
  id                   Int          @id @default(autoincrement())
  drawing_id           Int
  drawing              shop_drawing @relation(fields: [drawing_id], references: [id], onDelete: Cascade)
  revision             String       @db.VarChar(5)
  sequence             Int
  change_summary       String?      @db.Text
  file_url             String       @db.VarChar(500)
  file_size_bytes      BigInt?
  file_mime_type       String?      @db.VarChar(60)
  file_checksum_sha256 String?      @db.VarChar(64)
  approved_uid         Int?
  approver             res_users?   @relation("DrawingApprover", fields: [approved_uid], references: [id])
  approved_date        DateTime?    @db.Timestamptz
  is_current           Boolean      @default(false)
  create_uid           Int
  create_user          res_users    @relation("revision_create", fields: [create_uid], references: [id])
  create_date          DateTime     @default(now()) @db.Timestamptz

  @@unique([drawing_id, revision])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 4: Routing + Work Center + Std Time
// ═══════════════════════════════════════════════════════════════

// ── 🟧 Operation Type (BDT-custom — palette for RoutingBuilder) ──
model mrp_op_type {
  id              Int             @id @default(autoincrement())
  key             String          @unique @db.VarChar(30)
  label           String          @db.VarChar(60)
  color           String          @default("#555555") @db.VarChar(10)
  default_op_code String?         @db.VarChar(10)
  method_options  Json?
  sequence        Int             @default(10)
  is_active       Boolean         @default(true)
  default_wc_id   Int?
  default_wc      mrp_workcenter? @relation(fields: [default_wc_id], references: [id])
  create_date     DateTime        @default(now()) @db.Timestamptz
  write_date      DateTime        @default(now()) @db.Timestamptz

  routing_ops         mrp_routing_workcenter[]
  operation_templates operation_template[]
}

// ── 🟨 Work Center (Odoo mrp.workcenter + ISA-95/Siemens enrichment) ──
model mrp_workcenter {
  id                       Int              @id @default(autoincrement())
  code                     String           @unique @db.VarChar(20)
  name                     String           @db.VarChar(60)
  sequence                 Int              @default(10)
  active                   Boolean          @default(true)
  // Capacity & calendar
  capacity                 Decimal          @default(1.0) @db.Decimal(8, 2)
  working_hours_per_week   Decimal          @default(40) @db.Decimal(6, 2)
  time_efficiency          Decimal          @default(100) @db.Decimal(5, 2)
  time_start               Decimal          @default(0) @db.Decimal(8, 2)
  time_stop                Decimal          @default(0) @db.Decimal(8, 2)
  // OEE — ISA-95 A × P × Q split
  oee_target               Decimal          @default(90) @db.Decimal(5, 2)
  availability             Decimal          @default(100) @db.Decimal(5, 2)
  performance              Decimal          @default(100) @db.Decimal(5, 2)
  quality                  Decimal          @default(100) @db.Decimal(5, 2)
  // BDT-custom: Labor Mix JSONB {operator, skilled, group_head} in %
  labor_mix                Json             @default("{\"operator\":100,\"skilled\":0,\"group_head\":0}")
  // Cost components (THB/min)
  labor_cost_per_min       Decimal          @default(0) @db.Decimal(10, 4)
  electricity_cost_per_min Decimal          @default(0) @db.Decimal(10, 4)
  consumable_cost_per_min  Decimal          @default(0) @db.Decimal(10, 4)
  overhead_cost_per_min    Decimal          @default(0) @db.Decimal(10, 4)
  // Capacity per period snapshot {kg_per_month, m_per_month, pc_per_month}
  capacity_per_period      Json?
  // ISA-95 hierarchy
  parent_id                Int?
  parent                   mrp_workcenter?  @relation("WCParent", fields: [parent_id], references: [id])
  children                 mrp_workcenter[] @relation("WCParent")
  resource_type            String           @default("workcenter") @db.VarChar(20)
  shared_resource_tag      String?          @db.VarChar(40)
  // Audit
  odoo_ref_id              String?          @db.VarChar(40)
  create_uid               Int
  create_user              res_users        @relation("wc_create", fields: [create_uid], references: [id])
  create_date              DateTime         @default(now()) @db.Timestamptz
  write_uid                Int
  write_user               res_users        @relation("wc_write", fields: [write_uid], references: [id])
  write_date               DateTime         @default(now()) @db.Timestamptz

  routing_workcenters mrp_routing_workcenter[]
  op_types            mrp_op_type[]
  operation_templates operation_template[]
  work_orders         work_order[]             @relation("wo_workcenter") // Sprint 14: WO op snapshot
}

// ── 🟦 Routing Operation (Odoo mrp.routing.workcenter — Sprint 4.2: bound to template) ──
model mrp_routing_workcenter {
  id                  Int              @id @default(autoincrement())
  // Sprint 4.2: bound to routing_template (no more per-product rows)
  template_id         Int
  template            routing_template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  name                String           @db.VarChar(60)
  op_code             String           @db.VarChar(30)
  sequence            Int              @default(10)
  workcenter_id       Int
  workcenter          mrp_workcenter   @relation(fields: [workcenter_id], references: [id])
  // Time (Odoo-compat)
  time_cycle          Decimal          @default(0) @db.Decimal(10, 4)
  time_cycle_manual   Decimal?         @db.Decimal(10, 4)
  time_mode           String           @default("formula") @db.VarChar(10)
  // BDT-custom
  routing_view        String           @default("eRoute") @db.VarChar(10)
  method              String?          @db.VarChar(20)
  formula_expr        String?          @db.VarChar(400)
  op_type_id          Int?
  op_type             mrp_op_type?     @relation(fields: [op_type_id], references: [id])
  // Computed cache (template-level — averaged across all bound products)
  last_computed_at    DateTime?        @db.Timestamptz
  cache_key           String?          @db.VarChar(64)
  // Canvas position (RoutingBuilder)
  canvas_x            Float?
  canvas_y            Float?
  // Activities snapshot (JSON array saved by RoutingBuilder canvas)
  activities_snapshot Json?
  // Dependencies (Sprint 5+)
  blocked_by_op_ids   Int[]            @default([])
  // Audit
  create_uid          Int
  create_user         res_users        @relation("rwc_create", fields: [create_uid], references: [id])
  create_date         DateTime         @default(now()) @db.Timestamptz
  write_uid           Int
  write_user          res_users        @relation("rwc_write", fields: [write_uid], references: [id])
  write_date          DateTime         @default(now()) @db.Timestamptz

  bom_lines product_bom_line[] @relation("BomLineOp")

  @@unique([template_id, sequence], map: "ux_routing_op_seq_per_template")
  @@index([template_id])
}

// ── 🟥 Formula Parameter Registry (BDT-custom cycle-time formulas) ──
model routing_formula_param {
  code               String   @id @db.VarChar(40)
  description        String   @db.VarChar(200)
  formula_expression String   @db.VarChar(400)
  inputs_required    String[]
  return_unit        String   @db.VarChar(20)
  applies_to_groups  String[]
  active             Boolean  @default(true)
  create_date        DateTime @default(now()) @db.Timestamptz
  write_date         DateTime @default(now()) @db.Timestamptz
}

// ═══════════════════════════════════════════════════════════════
// Sprint 4.2: Routing Option 3 — Template + Override + Custom
// ═══════════════════════════════════════════════════════════════

// ── 🟦 Routing Template (shared recipe across many products) ─────
model routing_template {
  id                      Int               @id @default(autoincrement())
  code                    String            @unique @db.VarChar(20) // 'Main' | 'Accessory' | 'False'
  name                    String            @db.VarChar(60)
  description             String?           @db.Text
  version                 String            @default("1.0") @db.VarChar(10)
  state                   String            @default("active") @db.VarChar(20)
  active                  Boolean           @default(true)
  applies_to_product_type String?           @db.VarChar(20) // 'standard'|'custom'|null = both
  applies_to_categ_id     Int?
  bg_image_url            String?           @db.VarChar(500)
  bg_rotation             Float?            @default(0)
  bg_scale                Float?            @default(1)
  canvas_edges            Json?
  applies_to_categ        product_category? @relation(fields: [applies_to_categ_id], references: [id])
  // Audit
  create_uid              Int
  create_user             res_users         @relation("rt_create", fields: [create_uid], references: [id])
  create_date             DateTime          @default(now()) @db.Timestamptz
  write_uid               Int
  write_user              res_users         @relation("rt_write", fields: [write_uid], references: [id])
  write_date              DateTime          @default(now()) @db.Timestamptz

  // Sprint 13 · P7: forward-looking DBR/TOC anchor → mrp_routing_workcenter.id (soft ref)
  bottleneck_op_id Int?

  operations           mrp_routing_workcenter[]
  binding_rules        routing_template_binding_rule[]
  bound_products       products[]                      @relation("ProductTemplateBind")
  history              routing_template_history[]      @relation("TemplateHistory")
  test_fixtures        routing_template_test_fixture[]
  manufacturing_orders manufacturing_order[] // Sprint 13: MO snapshot source

  @@index([state])
}

// ── 🟨 Template Binding Rule (engineer-editable, priority-ordered rule chain) ──
model routing_template_binding_rule {
  id                  Int              @id @default(autoincrement())
  priority            Int              @default(100) // lower = higher priority
  description         String?          @db.Text
  // Match criteria (AND — all set fields must match)
  match_product_type  String?          @db.VarChar(20) // 'standard' | 'custom'
  match_mark_prefix   String?          @db.VarChar(10)
  match_categ_id      Int?
  match_attr_path     String?          @db.VarChar(60) // e.g. 'attributes.material_group'
  match_attr_value    String?          @db.VarChar(60)
  // Action
  routing_template_id Int
  routing_template    routing_template @relation(fields: [routing_template_id], references: [id])
  active              Boolean          @default(true)
  // Audit (lightweight — no user FK to keep seed simple)
  create_uid          Int              @default(1)
  create_date         DateTime         @default(now()) @db.Timestamptz
  write_uid           Int              @default(1)
  write_date          DateTime         @default(now()) @db.Timestamptz

  @@index([priority, active])
  @@index([routing_template_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 4.3: Template Simulator Fixtures (RT47)
// ═══════════════════════════════════════════════════════════════

// ── 🟨 Saved simulator inputs as regression test fixtures ─────
model routing_template_test_fixture {
  id                  Int              @id @default(autoincrement())
  template_id         Int
  template            routing_template @relation(fields: [template_id], references: [id], onDelete: Cascade)
  name                String           @db.VarChar(80) // e.g. 'Standard 1500 kg / 12 m column'
  description         String?          @db.Text
  source_mode         String           @db.VarChar(20) // 'pick_product' | 'manual'
  source_product_id   Int?
  source_product      products?        @relation("FixtureProduct", fields: [source_product_id], references: [id])
  attribute_values    Json // resolved attribute values used (for replay)
  expected_total_min  Decimal?         @db.Decimal(10, 2)
  expected_total_cost Decimal?         @db.Decimal(12, 2)
  // Audit
  create_uid          Int
  create_user         res_users        @relation("rtf_create", fields: [create_uid], references: [id])
  create_date         DateTime         @default(now()) @db.Timestamptz

  @@index([template_id])
  @@index([source_product_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 4.3: Layer-1 History Tables (RT48/RT49)
// ═══════════════════════════════════════════════════════════════

// ── 🟦 routing_template history ──────────────────────────────
model routing_template_history {
  id             Int              @id @default(autoincrement())
  template_id    Int
  template       routing_template @relation("TemplateHistory", fields: [template_id], references: [id], onDelete: Cascade)
  version        String           @db.VarChar(20)
  snapshot       Json // full mutable-field snapshot of routing_template at time of change
  changed_by_uid Int
  changed_by     res_users        @relation("rth_user", fields: [changed_by_uid], references: [id])
  changed_at     DateTime         @default(now()) @db.Timestamptz
  eco_id         Int? // ⏳ Sprint 5 mrp_eco FK
  reason         String?          @db.Text

  @@index([template_id, changed_at])
  @@index([eco_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 7: BOM Upload (dispatch + doc_revision + assembly + part)
// ═══════════════════════════════════════════════════════════════

// ── 🟥 BOM Dispatch (one upload session = one dispatch) ──────────
model bom_dispatch {
  id                    Int          @id @default(autoincrement())
  project_id            Int
  project               project      @relation("ProjectDispatches", fields: [project_id], references: [id])
  zone_id               Int
  zone                  project_zone @relation("ZoneDispatches", fields: [zone_id], references: [id])
  sub_zone_id           Int?
  sub_zone              sub_zone?    @relation("SubZoneDispatches", fields: [sub_zone_id], references: [id])
  status                String       @default("draft") @db.VarChar(20) // draft | processing | ready | error
  uploaded_at           DateTime     @default(now()) @db.Timestamptz
  // Aggregate counts — cached after processing
  assembly_total        Int?
  part_total            Int?
  // mBOM coverage — saved after welding compute()
  welding_coverage_json Json?
  // Audit
  create_uid            Int
  create_user           res_users    @relation("dispatch_create", fields: [create_uid], references: [id])
  create_date           DateTime     @default(now()) @db.Timestamptz
  write_uid             Int
  write_user            res_users    @relation("dispatch_write", fields: [write_uid], references: [id])
  write_date            DateTime     @default(now()) @db.Timestamptz

  doc_revisions            bom_doc_revision[]
  assemblies               bom_assembly[]
  parts                    bom_part[]
  paint_configs            dispatch_assembly_paint_config[]   @relation("DispatchPaintConfigs")
  material_requirements    dispatch_material_requirement[]    @relation("DispatchMaterialReqs")
  assembly_welding_configs dispatch_assembly_welding_config[] @relation("DispatchAssemblyWeldingConfigs")
  welding_requirements     dispatch_welding_requirement[]     @relation("DispatchWeldingReqs")

  @@index([project_id, status])
  @@index([zone_id])
  @@index([uploaded_at])
}

// ── 🟥 BOM Doc Revision (one file per doc_type per dispatch) ─────
model bom_doc_revision {
  id                   Int          @id @default(autoincrement())
  dispatch_id          Int
  dispatch             bom_dispatch @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)
  doc_type             String       @db.VarChar(30) // ASSEMBLY_LIST | ASSEMBLY_PART_LIST | PART_LIST
  original_filename    String       @db.VarChar(255)
  storage_key          String       @db.VarChar(500) // path in LocalFileStorageDriver
  file_size_bytes      BigInt?
  file_mime_type       String?      @db.VarChar(60)
  file_checksum_sha256 String?      @db.VarChar(64)
  // Audit (immutable after create)
  create_uid           Int
  create_user          res_users    @relation("docrev_create", fields: [create_uid], references: [id])
  create_date          DateTime     @default(now()) @db.Timestamptz

  @@unique([dispatch_id, doc_type])
  @@index([dispatch_id])
}

// ── 🟥 BOM Assembly (soft ref — assembly_mark is a plain string) ─
model bom_assembly {
  id              Int          @id @default(autoincrement())
  dispatch_id     Int
  dispatch        bom_dispatch @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)
  assembly_mark   String       @db.VarChar(60) // e.g. "WH-CO-001" — soft ref, no FK to products
  name            String?      @db.VarChar(200)
  qty             Decimal?     @db.Decimal(12, 3)
  weight_kg       Decimal?     @db.Decimal(12, 3)
  surface_area_m2 Decimal?     @db.Decimal(12, 4)
  length_mm       Decimal?     @db.Decimal(12, 2)
  width_mm        Decimal?     @db.Decimal(12, 2)
  height_mm       Decimal?     @db.Decimal(12, 2)
  attributes      Json         @default("{}")
  // Sprint 8: eBOM ↔ mBOM mapping
  product_id      Int?
  product         products?    @relation(fields: [product_id], references: [id], onDelete: SetNull)
  match_status    String?      @db.VarChar(20) // MATCHED_STANDARD | MATCHED_CUSTOM | AUTO_CREATED
  // Audit
  create_uid      Int
  create_user     res_users    @relation("assembly_create", fields: [create_uid], references: [id])
  create_date     DateTime     @default(now()) @db.Timestamptz
  write_uid       Int
  write_user      res_users    @relation("assembly_write", fields: [write_uid], references: [id])
  write_date      DateTime     @default(now()) @db.Timestamptz

  assembly_parts    bom_assembly_part[]
  paint_configs     dispatch_assembly_paint_config[]   @relation("AssemblyPaintConfigs")
  welding_configs   dispatch_assembly_welding_config[] @relation("AssemblyWeldingConfig")
  mo_assembly_lines mo_assembly_line[] // Sprint 13: MO allocation (P17)
  work_orders       work_order[] // Sprint 14: WO execution (F-WO)

  @@unique([dispatch_id, assembly_mark])
  @@index([dispatch_id])
  @@index([product_id])
}

// ── 🟥 BOM Part (soft ref — part_mark is a plain string) ─────────
model bom_part {
  id           Int          @id @default(autoincrement())
  dispatch_id  Int
  dispatch     bom_dispatch @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)
  part_mark    String       @db.VarChar(60) // e.g. "WH-CO-001-P01" — soft ref
  description  String?      @db.VarChar(200)
  profile      String?      @db.VarChar(60)
  grade        String?      @db.VarChar(20)
  qty          Decimal?     @db.Decimal(12, 3)
  length_mm    Decimal?     @db.Decimal(10, 2)
  weight_kg    Decimal?     @db.Decimal(12, 3)
  attributes   Json         @default("{}")
  // Sprint 8: eBOM ↔ mBOM mapping
  product_id   Int?
  product      products?    @relation(fields: [product_id], references: [id], onDelete: SetNull)
  match_status String?      @db.VarChar(20) // MATCHED_STANDARD | MATCHED_CUSTOM | AUTO_CREATED
  // Audit
  create_uid   Int
  create_user  res_users    @relation("part_create", fields: [create_uid], references: [id])
  create_date  DateTime     @default(now()) @db.Timestamptz
  write_uid    Int
  write_user   res_users    @relation("part_write", fields: [write_uid], references: [id])
  write_date   DateTime     @default(now()) @db.Timestamptz

  assembly_parts bom_assembly_part[]

  @@unique([dispatch_id, part_mark])
  @@index([dispatch_id])
  @@index([product_id])
}

// ── 🟥 BOM Assembly-Part Junction ───────────────────────────────
model bom_assembly_part {
  id          Int          @id @default(autoincrement())
  assembly_id Int
  assembly    bom_assembly @relation(fields: [assembly_id], references: [id], onDelete: Cascade)
  part_id     Int
  part        bom_part     @relation(fields: [part_id], references: [id], onDelete: Cascade)
  qty         Decimal      @default(1) @db.Decimal(12, 3)
  sequence    Int?
  // Audit (immutable after create)
  create_uid  Int
  create_user res_users    @relation("asmpart_create", fields: [create_uid], references: [id])
  create_date DateTime     @default(now()) @db.Timestamptz

  @@unique([assembly_id, part_id])
  @@index([assembly_id])
  @@index([part_id])
}

// ── Sprint 9: mBOM Paint Config per dispatch assembly ──────────
model dispatch_assembly_paint_config {
  id          Int          @id @default(autoincrement())
  dispatch_id Int
  dispatch    bom_dispatch @relation("DispatchPaintConfigs", fields: [dispatch_id], references: [id], onDelete: Cascade)
  assembly_id Int
  assembly    bom_assembly @relation("AssemblyPaintConfigs", fields: [assembly_id], references: [id], onDelete: Cascade)
  paint_type  String       @db.VarChar(20)
  material_id Int?
  material    materials?   @relation("PaintConfigMaterial", fields: [material_id], references: [id], onDelete: SetNull)
  layers      Int          @default(1)
  create_uid  Int
  create_date DateTime     @default(now()) @db.Timestamptz
  write_uid   Int
  write_date  DateTime     @default(now()) @db.Timestamptz

  @@unique([assembly_id, paint_type])
  @@index([dispatch_id])
  @@index([assembly_id])
  @@index([material_id])
}

// ── Sprint 9: Computed mBOM material requirement per dispatch ───
model dispatch_material_requirement {
  id               Int          @id @default(autoincrement())
  dispatch_id      Int
  dispatch         bom_dispatch @relation("DispatchMaterialReqs", fields: [dispatch_id], references: [id], onDelete: Cascade)
  material_id      Int
  material         materials    @relation("MaterialRequirements", fields: [material_id], references: [id])
  paint_type       String       @db.VarChar(20)
  total_area_m2    Decimal      @db.Decimal(14, 4)
  total_qty_gallon Decimal      @db.Decimal(14, 4)
  computed_at      DateTime     @default(now()) @db.Timestamptz

  @@unique([dispatch_id, material_id, paint_type])
  @@index([dispatch_id])
  @@index([material_id])
}

// ── Sprint 9 (Wire): welding config per assembly ─────────────
model dispatch_assembly_welding_config {
  id          Int          @id @default(autoincrement())
  dispatch_id Int
  dispatch    bom_dispatch @relation("DispatchAssemblyWeldingConfigs", fields: [dispatch_id], references: [id], onDelete: Cascade)
  assembly_id Int
  assembly    bom_assembly @relation("AssemblyWeldingConfig", fields: [assembly_id], references: [id], onDelete: Cascade)
  material_id Int?
  material    materials?   @relation("AssemblyWeldingConfigMaterial", fields: [material_id], references: [id], onDelete: SetNull)
  fillet_mm   Decimal?     @db.Decimal(4, 1)
  sides       Int?
  weld_layers Int?
  create_uid  Int
  create_date DateTime     @default(now()) @db.Timestamptz
  write_uid   Int
  write_date  DateTime     @default(now()) @db.Timestamptz

  @@unique([dispatch_id, assembly_id])
  @@index([dispatch_id])
  @@index([assembly_id])
  @@index([material_id])
}

// ── Sprint 9 (Wire): computed welding requirement per dispatch ─
model dispatch_welding_requirement {
  id                   Int          @id @default(autoincrement())
  dispatch_id          Int
  dispatch             bom_dispatch @relation("DispatchWeldingReqs", fields: [dispatch_id], references: [id], onDelete: Cascade)
  material_id          Int
  material             materials    @relation("WeldingRequirements", fields: [material_id], references: [id])
  total_path_m         Decimal      @db.Decimal(14, 4)
  total_consumption_kg Decimal      @db.Decimal(14, 4)
  total_packages       Int
  computed_at          DateTime     @default(now()) @db.Timestamptz

  @@unique([dispatch_id, material_id])
  @@index([dispatch_id])
  @@index([material_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 11: Operation Library (operation_template)
// ═══════════════════════════════════════════════════════════════

model operation_template {
  id            Int             @id @default(autoincrement())
  op_code       String          @unique @db.VarChar(40)
  name          String          @db.VarChar(100)
  op_type_id    Int?
  op_type       mrp_op_type?    @relation(fields: [op_type_id], references: [id])
  workcenter_id Int?
  workcenter    mrp_workcenter? @relation(fields: [workcenter_id], references: [id])
  method        String?         @db.VarChar(20)
  time_mode     String          @default("formula") @db.VarChar(20)
  duration_min  Decimal?        @db.Decimal(10, 4)
  formula_expr  String?         @db.VarChar(400)
  status        String          @default("draft") @db.VarChar(10)
  create_uid    Int             @default(1)
  create_date   DateTime        @default(now()) @db.Timestamptz
  write_uid     Int             @default(1)
  write_date    DateTime        @default(now()) @db.Timestamptz

  activities operation_template_activity[]
}

model operation_template_activity {
  id                    Int                 @id @default(autoincrement())
  operation_template_id Int
  operation_template    operation_template  @relation(fields: [operation_template_id], references: [id], onDelete: Cascade)
  sequence              Int                 @default(10)
  name                  String              @db.VarChar(200)
  measure               String              @db.VarChar(40)
  unit                  String?             @db.VarChar(20)
  per_minute            Decimal?            @db.Decimal(10, 4)
  machine_id            Int?
  machine               equipment_resource? @relation("OpActMachine", fields: [machine_id], references: [id], onDelete: SetNull)
  source_activity_id    Int?
  source_activity       activity?           @relation("OpActSourceActivity", fields: [source_activity_id], references: [id], onDelete: SetNull)
  snapshot_at           DateTime?           @db.Timestamptz
  tools                 op_act_tool[]
  labors                op_act_labor[]
  op_materials          op_act_material[]

  @@index([operation_template_id])
}

// ── T-MACH.01: Machine Tracker enums ─────────────────────────────────────────
enum EquipmentStatus {
  OPERATIONAL
  MAINTENANCE
  REPAIR
  UNAVAILABLE
  RETIRED
}

enum RepairStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum RepairSeverity {
  LOW
  MEDIUM
  HIGH
}

// ── Equipment Resource Master (Phase 3) ──────────────────────────────────────
model equipment_resource {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(30)
  name        String   @db.VarChar(80)
  type        String   @db.VarChar(20) // 'machine' | 'handling' | 'labor' | 'tool' | 'consumable'
  rate        Decimal? @db.Decimal(10, 4)
  rate_unit   String?  @db.VarChar(20)
  active      Boolean  @default(true)
  create_date DateTime @default(now()) @db.Timestamptz
  write_date  DateTime @updatedAt @db.Timestamptz

  // T-MACH.01: Machine Tracker fields
  current_status      EquipmentStatus @default(OPERATIONAL)
  last_maintenance_at DateTime?
  location            String?         @db.VarChar(120)
  manufacturer        String?         @db.VarChar(120)
  model               String?         @db.VarChar(120)
  serial_number       String?         @db.VarChar(120)
  install_date        DateTime?
  specs               String?         @db.Text
  photo_url           String?

  operation_template_acts operation_template_activity[] @relation("OpActMachine")
  op_act_tools            op_act_tool[]
  // Sprint 11: Activity Library
  activities              activity[]                    @relation("activity_machine")
  activity_labors         activity_labor[]              @relation("activity_labor_resource")
  activity_consumes       activity_consume[]            @relation("activity_consume_resource")
  activity_tools          activity_tool[]               @relation("activity_tool_resource")
  op_act_labors           op_act_labor[]                @relation("OpActLaborResource")
  op_act_materials        op_act_material[]             @relation("op_act_material_resource")
  // T-MACH.01: Machine Tracker relations
  maintenance_logs        maintenance_log[]
  repair_tickets          repair_ticket[]
  status_history          machine_status_history[]
  // Sprint 14: schedule workcenter line (F-WO · Q14b=C)
  prod_schedules          prod_schedule[]               @relation("sched_workcenter_line")
}

model op_act_tool {
  id          Int                         @id @default(autoincrement())
  activity_id Int
  activity    operation_template_activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  resource_id Int
  resource    equipment_resource          @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@unique([activity_id, resource_id])
  @@index([activity_id])
}

// ── Sprint 11b: Op-act snapshot tables ───────────────────────────────────────
// Note: these models use `op_act_id` (not `activity_id`) to avoid ambiguity
// with op_act_tool/op_act_consumable which pre-date this naming.

model op_act_labor {
  id                Int                         @id @default(autoincrement())
  op_act_id         Int
  op_act            operation_template_activity @relation(fields: [op_act_id], references: [id], onDelete: Cascade)
  labor_resource_id Int
  labor_resource    equipment_resource          @relation("OpActLaborResource", fields: [labor_resource_id], references: [id], onDelete: Cascade)
  qty               Int                         @default(1)

  @@unique([op_act_id, labor_resource_id])
  @@index([op_act_id])
}

model op_act_material {
  id          Int                         @id @default(autoincrement())
  op_act_id   Int
  op_act      operation_template_activity @relation(fields: [op_act_id], references: [id], onDelete: Cascade)
  resource_id Int
  resource    equipment_resource          @relation("op_act_material_resource", fields: [resource_id], references: [id], onDelete: Cascade)

  @@unique([op_act_id, resource_id])
  @@index([op_act_id])
}

// ═══════════════════════════════════════════════════════════════
// Sprint 12: Activity Library
// ═══════════════════════════════════════════════════════════════

model activity {
  id                            Int                           @id @default(autoincrement())
  activity_code                 String                        @unique @db.VarChar(20)
  name                          String                        @db.VarChar(120)
  machine_id                    Int
  machine                       equipment_resource            @relation("activity_machine", fields: [machine_id], references: [id])
  duration_min                  Decimal                       @db.Decimal(10, 2)
  create_uid                    Int
  create_user                   res_users                     @relation("activity_create_user", fields: [create_uid], references: [id])
  create_date                   DateTime                      @default(now()) @db.Timestamptz
  write_uid                     Int
  write_user                    res_users                     @relation("activity_write_user", fields: [write_uid], references: [id])
  write_date                    DateTime                      @updatedAt @db.Timestamptz
  consumes                      activity_consume[]
  labors                        activity_labor[]
  tools                         activity_tool[]
  operation_template_activities operation_template_activity[] @relation("OpActSourceActivity")

  @@index([machine_id])
  @@index([name])
}

model activity_consume {
  activity_id Int
  resource_id Int
  activity    activity           @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  resource    equipment_resource @relation("activity_consume_resource", fields: [resource_id], references: [id], onDelete: Cascade)

  @@id([activity_id, resource_id])
  @@index([resource_id])
}

model activity_labor {
  activity_id       Int
  labor_resource_id Int
  qty               Int                @default(1)
  activity          activity           @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  labor_resource    equipment_resource @relation("activity_labor_resource", fields: [labor_resource_id], references: [id])

  @@id([activity_id, labor_resource_id])
  @@index([labor_resource_id])
}

model activity_tool {
  activity_id Int
  resource_id Int
  activity    activity           @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  resource    equipment_resource @relation("activity_tool_resource", fields: [resource_id], references: [id], onDelete: Cascade)

  @@id([activity_id, resource_id])
  @@index([resource_id])
}

model activity_code_seq {
  id       Int @id
  next_val Int @default(1)
}

// ── T-MACH.01: Machine Tracker tables ────────────────────────────────────────
model maintenance_log {
  id             Int                @id @default(autoincrement())
  machine_id     Int
  machine        equipment_resource @relation(fields: [machine_id], references: [id])
  performed_at   DateTime
  performed_by   String             @db.VarChar(120)
  description    String             @db.Text
  parts_replaced String?            @db.Text
  duration_min   Int?
  notes          String?            @db.Text
  photo_urls     String[]
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
}

model repair_ticket {
  id                  Int                @id @default(autoincrement())
  machine_id          Int
  machine             equipment_resource @relation(fields: [machine_id], references: [id])
  ticket_code         String             @unique @db.VarChar(20)
  status              RepairStatus       @default(OPEN)
  severity            RepairSeverity
  reported_by         String             @db.VarChar(120)
  reported_at         DateTime
  problem_description String             @db.Text
  photos_before       String[]
  repaired_by         String?            @db.VarChar(120)
  closed_at           DateTime?
  repair_description  String?            @db.Text
  parts_replaced      String?            @db.Text
  duration_min        Int?
  photos_after        String[]
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
}

model machine_status_history {
  id                     Int                @id @default(autoincrement())
  machine_id             Int
  machine                equipment_resource @relation(fields: [machine_id], references: [id])
  from_status            EquipmentStatus
  to_status              EquipmentStatus
  reason                 String             @db.Text
  changed_by             String             @db.VarChar(120)
  changed_at             DateTime           @default(now())
  related_repair_id      Int?
  related_maintenance_id Int?
}

// ── 🟥 Custom: repair_ticket_seq (RPR-NNNNN counter) ─────────
model repair_ticket_seq {
  id       Int @id
  next_val Int @default(1)
}

// ═══════════════════════════════════════════════════════════════
// Sprint 13: F-MO · Manufacturing Order pilot
//   MO = planning envelope over BOM + Routing. Structure-only (no
//   per-op timestamps — those belong to Work Order, Sprint 14+).
// ═══════════════════════════════════════════════════════════════

enum MoStatus {
  DRAFT // editable · allocation locked from DRAFT (P15)
  CONFIRMED // ready for execution · no edits
  IN_PROGRESS // execution started
  DONE // completed
  CANCELLED // void · allocation returned (P15)
}

model manufacturing_order {
  id                       Int                @id @default(autoincrement())
  mo_code                  String             @unique @db.VarChar(20) // MO-00001 · race-safe via mo_code_seq (P5)
  // P12: exactly 1 mark prefix per MO. FK by code (mark_prefix_master PK = code).
  primary_mark_prefix_code String             @db.VarChar(10)
  primary_mark_prefix      mark_prefix_master @relation(fields: [primary_mark_prefix_code], references: [code])
  // P12: exactly 1 routing template per MO. Operations snapshotted at create (ADR-0012).
  routing_template_id      Int
  routing_template         routing_template   @relation(fields: [routing_template_id], references: [id])
  status                   MoStatus           @default(DRAFT)
  // P21: due date only (DATE, no time).
  due_date                 DateTime?          @db.Date
  // Audit (parent only; children inherit lifecycle via cascade)
  create_uid               Int
  create_user              res_users          @relation("mo_create", fields: [create_uid], references: [id])
  create_date              DateTime           @default(now()) @db.Timestamptz
  write_uid                Int
  write_user               res_users          @relation("mo_write", fields: [write_uid], references: [id])
  write_date               DateTime           @updatedAt @db.Timestamptz

  assembly_lines mo_assembly_line[]
  status_history mo_status_history[]
  work_orders    work_order[] // Sprint 14: execution layer (F-WO)

  @@index([status])
  @@index([primary_mark_prefix_code])
  @@index([routing_template_id])
  @@index([due_date])
}

// P13/P15/P17 · partial allocation line. qty ≤ remaining; locked from DRAFT.
model mo_assembly_line {
  id              Int                 @id @default(autoincrement())
  mo_id           Int
  mo              manufacturing_order @relation(fields: [mo_id], references: [id], onDelete: Cascade)
  bom_assembly_id Int // P17: granularity anchor = bom_assembly (not bom_dispatch)
  bom_assembly    bom_assembly        @relation(fields: [bom_assembly_id], references: [id])
  qty             Decimal             @db.Decimal(12, 3) // P13 · ≤ remaining at create time
  line_seq        Int                 @default(0)

  @@unique([mo_id, bom_assembly_id]) // no duplicate assemblies within one MO
  @@index([bom_assembly_id])
}

// MO-level audit trail only (operation activity → WO, Sprint 14+).
model mo_status_history {
  id          Int                 @id @default(autoincrement())
  mo_id       Int
  mo          manufacturing_order @relation(fields: [mo_id], references: [id], onDelete: Cascade)
  from_status MoStatus
  to_status   MoStatus
  reason      String              @db.Text
  changed_by  String              @db.VarChar(120)
  changed_at  DateTime            @default(now()) @db.Timestamptz

  @@index([mo_id])
}

// 🟥 Custom: mo_code_seq (MO-NNNNN counter · SELECT FOR UPDATE, P5)
model mo_code_seq {
  id       Int @id
  next_val Int @default(1)
}

// ═══════════════════════════════════════════════════════════════════════════
// Sprint 14 · F-WO Work Order (execution layer · Q1=D 1 WO = 1 operation)
// WO header snapshots a mo_operation row; auto-created on MO confirm.
// ═══════════════════════════════════════════════════════════════════════════

model work_order {
  id                       Int       @id @default(autoincrement())
  wo_code                  String    @unique @db.VarChar(20) // WO-NNNNNNNN · race-safe via work_order_code_seq (Q18)
  mo_id                    Int
  source_routing_op_id     Int? // soft ref → mrp_routing_workcenter.id (snapshot immutable; replaces mo_operation_id)
  sequence                 Int // copied from mo_operation.sequence
  work_center_id           Int
  expected_duration_min    Int
  setup_time_min           Int
  op_attributes            Json      @default("{}")
  bom_assembly_id          Int
  bom_dispatch_id_snapshot Int // soft ref → bom_dispatch.id · drives BOM Version Alert (Q12=B)
  status                   WoStatus  @default(NOT_STARTED)
  earliest_start_at        DateTime? @db.Timestamptz // Q13=C · scheduling anchor on WO (priority dropped)
  actual_start_at          DateTime? @db.Timestamptz
  actual_end_at            DateTime? @db.Timestamptz
  target_end_at            DateTime? @db.Timestamptz
  qty_done                 Decimal?  @db.Decimal(12, 3)
  qty_scrapped             Decimal?  @db.Decimal(12, 3)
  assigned_to              String?   @db.VarChar(120)
  notes                    String?   @db.Text
  released_at              DateTime? @db.Timestamptz
  released_by              String?   @db.VarChar(120)
  created_at               DateTime  @default(now()) @db.Timestamptz
  updated_at               DateTime  @updatedAt @db.Timestamptz
  created_by               String    @db.VarChar(120)
  updated_by               String?   @db.VarChar(120)

  manufacturing_order manufacturing_order @relation(fields: [mo_id], references: [id], onDelete: Cascade)
  mrp_workcenter      mrp_workcenter      @relation("wo_workcenter", fields: [work_center_id], references: [id])
  bom_assembly        bom_assembly        @relation(fields: [bom_assembly_id], references: [id])
  events              work_order_event[]
  schedules           prod_schedule[]

  @@index([mo_id])
  @@index([status])
  @@index([work_center_id])
}

model work_order_event {
  id            Int         @id @default(autoincrement())
  work_order_id Int
  event_type    WoEventType
  notes         String?     @db.Text
  recorded_by   String      @db.VarChar(120)
  recorded_at   DateTime    @default(now()) @db.Timestamptz

  work_order work_order @relation(fields: [work_order_id], references: [id], onDelete: Cascade)

  @@index([work_order_id, recorded_at])
}

// 🟥 Custom: work_order_code_seq (WO-NNNNNNNN counter · SELECT FOR UPDATE, Q18)
model work_order_code_seq {
  id       Int @id
  next_val Int @default(1)
}

// Q14=B · schedule version container. Q14a=A · 1 active system-wide. Mockup-only this sprint.
model prod_schedule_version {
  id               Int      @id @default(autoincrement())
  version_code     String   @unique @db.VarChar(50)
  description      String?  @db.Text
  is_active        Boolean  @default(false)
  scheduler_source String?  @db.VarChar(50) // Q14c=B · python-aps | manual | what-if
  created_at       DateTime @default(now()) @db.Timestamptz
  created_by       String   @db.VarChar(120)

  schedules prod_schedule[]

  @@index([is_active])
}

model prod_schedule {
  id                       Int      @id @default(autoincrement())
  prod_schedule_version_id Int
  work_order_id            Int
  start_datetime           DateTime @db.Timestamptz
  end_datetime             DateTime @db.Timestamptz
  workcenter_line_id       Int? // Q14b=C · FK → equipment_resource.id (separate from work_order.work_center_id → mrp_workcenter)

  prod_schedule_version prod_schedule_version @relation(fields: [prod_schedule_version_id], references: [id], onDelete: Cascade)
  work_order            work_order            @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
  equipment_resource    equipment_resource?   @relation("sched_workcenter_line", fields: [workcenter_line_id], references: [id])

  @@index([prod_schedule_version_id])
  @@index([work_order_id])
}

enum WoStatus {
  NOT_STARTED
  RELEASED
  IN_PROGRESS
  PAUSED
  DONE
  CANCELLED
}

enum WoEventType {
  START
  PAUSE
  RESUME
  DONE
  CANCEL
  ACCEPT_VERSION // T-WO.04 · BOM Version Alert accept audit (delta vs design §4 — spec requires an event row)
}
