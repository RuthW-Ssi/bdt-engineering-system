# ---- Postgres (used by the Python solver via psycopg2) ----
# ⚠️ Direct connection (db.<ref>.supabase.co) is IPv6-only on Supabase now and
#    will NOT resolve on IPv4-only networks. Prefer the Supavisor POOLER below.
# Direct:  postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres
# Pooler:  postgresql://postgres.<ref>:PASSWORD@aws-<n>-<region>.pooler.supabase.com:5432/postgres
#          - user must be tenant-qualified: postgres.<ref>
#          - port 5432 = session mode (use this for run_local.py); 6543 = transaction mode
#          - cluster prefix is aws-0 OR aws-1 ("tenant not found" => wrong cluster, try the other)
# Verified working for this project (ref eebubyfkzeqhzwzqrqfz, region ap-northeast-1):
#   postgresql://postgres.eebubyfkzeqhzwzqrqfz:[YOUR-DB-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-DB-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres

# ---- Supabase API ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>             # safe for client (cockpit reads)
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret> # SERVER ONLY — bypasses RLS, never expose to client

# Optional
# SCHED_TZ_OFFSET_HOURS=7
